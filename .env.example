# LLM
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# Database (use Neon -pooler host for server-side pooling)
DATABASE_URL=postgresql://user:pass@host-pooler.region.aws.neon.tech/db?sslmode=require
DB_POOL_MIN=2
DB_POOL_MAX=20

# Pinecone
PINECONE_API_KEY=
PINECONE_INDEX_NAME=new-business-index
PINECONE_HOST=
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSION=1024
PINECONE_NAMESPACE=
PINECONE_DUMP_LIMIT=10

# Observability (optional, phase 2)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=agentic-rag

# API (optional)
API_PASSWORD=
